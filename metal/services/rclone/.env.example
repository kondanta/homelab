# Explicit list of Garage paths to sync to Proton Drive.
# Format: bucket/optional-prefix — only listed paths are synced (opt-in).
# Note: volsync uses a single shared Kopia repo with no per-app paths, so the
# entire bucket must be synced — per-prefix entries won't work. Kopia _log_*
# transaction files are excluded globally in sync.sh to keep Proton Drive readable.
# Examples:
#   postgres-backups/authentik     — just the authentik DB dumps
#   postgres-backups/paperless     — just the paperless-ngx DB dumps
#   volsync                        — all PVC backups (whole bucket)
SYNC_BUCKETS=postgres-backups/authentik postgres-backups/paperless volsync

# Cron schedule (Europe/Oslo timezone)
SYNC_SCHEDULE=0 4 * * *

TZ=Europe/Oslo
